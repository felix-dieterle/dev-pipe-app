<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Dev-Pipe connects to user-configured servers that may use plain HTTP.
        Android 9+ blocks cleartext (HTTP) traffic by default, so we explicitly
        permit it for all domains here. This covers localhost, LAN IPs, and any
        custom discovery/backend endpoints the user configures (e.g. a PHP
        discovery URL on a public host).
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
